{
  "entities": {
    "Task": {
      "title": "Task",
      "description": "A high-stakes mission deadline analyzed by ShieldAI.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the task" },
        "title": { "type": "string", "description": "Title of the task" },
        "deadline": { "type": "string", "description": "Target deadline ISO timestamp" },
        "context": { "type": "string", "description": "User notes or strategic context" },
        "priority": { "type": "string", "enum": ["low", "medium", "high", "critical"] },
        "riskLevel": { "type": "string", "enum": ["Low", "Medium", "High", "Critical"] },
        "riskFactor": { "type": "integer", "description": "Failure percentage from 0 to 100" },
        "assessment": { "type": "string", "description": "AI analysis of potential failure risk" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "energyLevel": { "type": "string" },
        "burnoutRisk": { "type": "integer" },
        "pacingSafetyRecommendation": { "type": "string" },
        "subtasks": { "type": "array" },
        "urgencyCurve": { "type": "array" },
        "rescueTriggers": { "type": "array" }
      },
      "required": ["id", "title", "deadline", "priority", "riskLevel", "riskFactor", "completed", "createdAt"]
    },
    "CalendarEvent": {
      "title": "CalendarEvent",
      "description": "An automated defensive event block injected into the user's workflow.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "start": { "type": "string" },
        "end": { "type": "string" },
        "type": { "type": "string", "enum": ["deadline", "milestone", "focus-block"] },
        "taskId": { "type": "string" },
        "subtaskId": { "type": "string" }
      },
      "required": ["id", "title", "start", "end", "type"]
    },
    "FocusSession": {
      "title": "FocusSession",
      "description": "A deep focus block completed by the user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "taskId": { "type": "string" },
        "subtaskId": { "type": "string" },
        "durationMinutes": { "type": "integer" },
        "completedAt": { "type": "string" },
        "moodBefore": { "type": "string" },
        "moodAfter": { "type": "string" }
      },
      "required": ["id", "durationMinutes", "completedAt"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "The user's productivity records, streaks, and milestone achievements.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "streak": { "type": "integer" },
        "lastActiveDate": { "type": "string" },
        "focusMinutesTotal": { "type": "integer" },
        "unlockedInsights": { "type": "array" },
        "unlockedMilestones": { "type": "array" },
        "onboardingComplete": { "type": "boolean" },
        "onboarding": { "type": "object" }
      },
      "required": ["userId", "streak", "lastActiveDate", "focusMinutesTotal", "unlockedInsights", "unlockedMilestones"]
    },
    "LearningProfile": {
      "title": "LearningProfile",
      "description": "The dynamic user work habit speed multipliers by category.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "categories": { "type": "object" }
      },
      "required": ["userId", "categories"]
    },
    "Settings": {
      "title": "Settings",
      "description": "User application configurations.",
      "type": "object",
      "properties": {
        "theme": { "type": "string" },
        "soundEnabled": { "type": "boolean" },
        "vibrationEnabled": { "type": "boolean" }
      }
    },
    "Preferences": {
      "title": "Preferences",
      "description": "User preferences for cognitive pacing and performance windows.",
      "type": "object",
      "properties": {
        "focusWindow": { "type": "string" },
        "workingHoursStart": { "type": "string" },
        "workingHoursEnd": { "type": "string" },
        "sleepBedtime": { "type": "string" },
        "sleepWakeTime": { "type": "string" }
      }
    },
    "AIMemory": {
      "title": "AIMemory",
      "description": "Future AI memory structures for context preservation and learning trends.",
      "type": "object",
      "properties": {
        "productivityPreferences": { "type": "object" },
        "historicalCompletionTimes": { "type": "object" },
        "energyTrends": { "type": "object" },
        "burnoutHistory": { "type": "object" },
        "aiPersonalization": { "type": "object" },
        "recommendationHistory": { "type": "array" }
      }
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Future analytics data storage.",
      "type": "object",
      "properties": {
        "productivityStats": { "type": "object" },
        "dailySummaries": { "type": "object" },
        "weeklySummaries": { "type": "object" },
        "aiUsage": { "type": "object" },
        "focusSessions": { "type": "object" },
        "burnoutMetrics": { "type": "object" }
      }
    },
    "Habit": {
      "title": "Habit",
      "description": "User habit tracking records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "frequency": { "type": "string" },
        "streak": { "type": "integer" }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "Cognitive notifications and system warnings log.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      }
    },
    "Activity": {
      "title": "Activity",
      "description": "User audit activity logging.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string" }
      }
    },
    "Usage": {
      "title": "Usage",
      "description": "User resource usage statistics.",
      "type": "object",
      "properties": {
        "tokensUsed": { "type": "integer" },
        "requestsCount": { "type": "integer" }
      }
    }
  },
  "firestore": {
    "/users/{userId}/profile/main": {
      "schema": { "$ref": "UserProfile" },
      "description": "Main profile document for user-scoped streaks and unlocked milestones."
    },
    "/users/{userId}/profile/learning": {
      "schema": { "$ref": "LearningProfile" },
      "description": "Dynamic time estimation multiplier mapping."
    },
    "/users/{userId}/settings/main": {
      "schema": { "$ref": "Settings" },
      "description": "Interface settings and parameters."
    },
    "/users/{userId}/preferences/main": {
      "schema": { "$ref": "Preferences" },
      "description": "Pacing rules preferences."
    },
    "/users/{userId}/aiMemory/main": {
      "schema": { "$ref": "AIMemory" },
      "description": "AI-personalization traits, energy indices, and history."
    },
    "/users/{userId}/analytics/main": {
      "schema": { "$ref": "Analytics" },
      "description": "Hourly focus sessions, burnout and stress patterns summaries."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": { "$ref": "Task" },
      "description": "Subcollection storing tasks belonging to the user."
    },
    "/users/{userId}/calendar/{eventId}": {
      "schema": { "$ref": "CalendarEvent" },
      "description": "Subcollection storing calendar blocks belonging to the user."
    },
    "/users/{userId}/habits/{habitId}": {
      "schema": { "$ref": "Habit" },
      "description": "Subcollection of active habits and cycles."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": { "$ref": "Notification" },
      "description": "Subcollection of alert signals and notification records."
    },
    "/users/{userId}/activity/{activityId}": {
      "schema": { "$ref": "Activity" },
      "description": "Subcollection of operational logs."
    },
    "/users/{userId}/usage/{usageId}": {
      "schema": { "$ref": "Usage" },
      "description": "Subcollection of token usage records."
    }
  }
}
